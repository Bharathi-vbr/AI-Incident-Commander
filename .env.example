APP_NAME=ai-incident-commander
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_FILE=logs/payment-api.log
REDIS_URL=redis://redis:6379/0
REQUEST_TIMEOUT_SECONDS=2.0
DB_POOL_SIZE=10
DEFAULT_SIMULATION_MODE=normal

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_API_URL=https://api.anthropic.com/v1/messages

SLACK_WEBHOOK_URL=

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

RUNBOOK_DIR=logs/runbooks
ALERT_ERROR_RATE_THRESHOLD_PERCENT=5.0
ALERT_P95_LATENCY_THRESHOLD_SECONDS=1.0
ALERT_TIMEOUT_THRESHOLD=3.0
ALERT_DB_EXHAUSTED_THRESHOLD=1.0
